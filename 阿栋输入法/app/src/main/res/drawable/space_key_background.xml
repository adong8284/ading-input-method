<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- 正常状态 -->
    <item android:state_pressed="false" android:state_focused="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/key_space" />
            <stroke android:width="1dp" android:color="@color/primary_variant" />
            <corners android:radius="@dimen/key_radius" />
        </shape>
    </item>
    
    <!-- 按下状态 -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_variant" />
            <stroke android:width="1dp" android:color="@color/primary" />
            <corners android:radius="@dimen/key_radius" />
        </shape>
    </item>
    
    <!-- 焦点状态 -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/key_space" />
            <stroke android:width="2dp" android:color="@color/primary" />
            <corners android:radius="@dimen/key_radius" />
        </shape>
    </item>
    
    <!-- 选中状态 -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary_variant" />
            <stroke android:width="2dp" android:color="@color/secondary" />
            <corners android:radius="@dimen/key_radius" />
        </shape>
    </item>
    
</selector>